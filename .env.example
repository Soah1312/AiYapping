# Firebase client config JSON string (frontend + API usage tracking)
VITE_FIREBASE_CONFIG={"apiKey":"","authDomain":"","projectId":"","storageBucket":"","messagingSenderId":"","appId":""}

# AI provider keys (one key per provider)
# Groq key pool (all vars starting with GROQ_KEY_ are auto-discovered)
GROQ_KEY_1=
# GROQ_KEY_2=
# GROQ_KEY_3=
# Optional backward-compatible fallback
# GROQ_API_KEY=

# Hugging Face key pool (all vars starting with HUGGINGFACE_KEY_ are auto-discovered)
HUGGINGFACE_KEY_1=
# HUGGINGFACE_KEY_2=
# Optional backward-compatible fallback
# HUGGINGFACE_API_KEY=

# Optional override for DeepSeek R1 endpoint.
# Default behavior uses Hugging Face router with deepseek-ai/DeepSeek-R1.
# Set this only if you host a custom OpenAI-compatible endpoint (for example, an HF Space).
# HUGGINGFACE_SPACE_DEEPSEEK_R1_URL=
# Optional model override when custom endpoint above is set (default: deepseek-ai/DeepSeek-R1)
# HUGGINGFACE_SPACE_DEEPSEEK_R1_MODEL=deepseek-ai/DeepSeek-R1

# NVIDIA key pool (all vars starting with NVIDIA_KEY_ are auto-discovered)
NVIDIA_KEY_1=
# NVIDIA_KEY_2=
# Optional backward-compatible fallback
# NVIDIA_API_KEY=


# Firebase client config JSON string (frontend + API usage tracking)
VITE_FIREBASE_CONFIG={"apiKey":"","authDomain":"","projectId":"","storageBucket":"","messagingSenderId":"","appId":""}

# AI provider keys (one key per provider)
# Groq key pool (all vars starting with GROQ_KEY_ are auto-discovered)
GROQ_KEY_1=
# GROQ_KEY_2=
# GROQ_KEY_3=
# Optional backward-compatible fallback
# GROQ_API_KEY=

# Hugging Face key pool (all vars starting with HUGGINGFACE_KEY_ are auto-discovered)
HUGGINGFACE_KEY_1=
# HUGGINGFACE_KEY_2=
# Optional backward-compatible fallback
# HUGGINGFACE_API_KEY=

# Optional dedicated Groq keys for title generation (/api/title)
# GROQ_TITLE_KEY_1=
# GROQ_TITLE_KEY_2=
# Optional dedicated fallback name for title generation
# GROQ_TITLE_API_KEY=

# Optional dedicated NVIDIA keys for title generation backup (/api/title)
# NVIDIA_TITLE_KEY_1=
# NVIDIA_TITLE_KEY_2=
# Optional dedicated fallback name for title generation backup
# NVIDIA_TITLE_API_KEY=

# GitHub Models key pool (token must include models scope)
GITHUB_MODELS_KEY_1=
# Optional additional keys
# GITHUB_MODELS_KEY_2=
# Optional fallback variable name
# GITHUB_MODELS_API_KEY=

# Optional override for DeepSeek R1 endpoint.
# Default behavior uses Hugging Face router with deepseek-ai/DeepSeek-R1.
# Set this only if you host a custom OpenAI-compatible endpoint (for example, an HF Space).
# HUGGINGFACE_SPACE_DEEPSEEK_R1_URL=
# Optional model override when custom endpoint above is set (default: deepseek-ai/DeepSeek-R1)
# HUGGINGFACE_SPACE_DEEPSEEK_R1_MODEL=deepseek-ai/DeepSeek-R1

# NVIDIA key pool (all vars starting with NVIDIA_KEY_ are auto-discovered)
NVIDIA_KEY_1=
# NVIDIA_KEY_2=
# Optional backward-compatible fallback
# NVIDIA_API_KEY=

# Admin dashboard password (server-side check in /api/admin)
MEOW_PASSWORD=
# Optional alternate name supported by code
# ADMIN_MEOW_PASSWORD=

# Firebase Admin SDK credentials for privileged server reads (required in production for /api/admin)
# Option A: Full service account JSON in one variable
FIREBASE_SERVICE_ACCOUNT_KEY=

# Option B: Individual fields (use this if not using FIREBASE_SERVICE_ACCOUNT_KEY)
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

